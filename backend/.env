# Application
APP_NAME=Multi-Agent Shopping Assistant
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./shopping.db
# For production: DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/shopping_db

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (optional)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Email (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@shoppingassistant.com

# HuggingFace
HF_MODEL_NAME=cardiffnlp/twitter-roberta-base-sentiment-latest

# RapidAPI - real Amazon prices (optional)
# Sign up: https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-amazon-data
RAPIDAPI_KEY=

# Google Custom Search API - real product images + exact product URLs
# Step 1: Get API key at https://developers.google.com/custom-search/v1/overview
# Step 2: Create engine at https://programmablesearchengine.google.com
#         Turn ON "Search the entire web", copy the cx value
# Free: 100 queries/day
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
GOOGLE_CLIENT_ID="697773351406-h9u3m8518u4pjkb1sp7b8cgqojl3bpeq.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="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"